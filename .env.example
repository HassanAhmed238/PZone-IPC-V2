# ─── PZone IPC V2 — Required Environment Variables ───
# Copy this file to .env and fill in your values.

# Supabase connection (REQUIRED)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...your-anon-key

# Admin email addresses (comma-separated, REQUIRED for production)
VITE_ADMIN_EMAILS=admin@pzone.com

# Dev bypass — set to "true" ONLY during local development to skip auth
# WARNING: Never set this in production!
VITE_DEV_BYPASS=true
